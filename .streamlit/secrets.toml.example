# ── Supabase 配置 ──────────────────────────────────────────
# 1. 前往 https://supabase.com 注册（免费）
# 2. 新建项目
# 3. 进入 SQL Editor，运行以下建表语句：
#
#    create table budget_data (
#      id text primary key default 'default',
#      data jsonb not null default '{}',
#      updated_at timestamptz default now()
#    );
#
# 4. 进入 Settings → API，复制 URL 和 anon/public key
# 5. 将此文件复制为 secrets.toml，填入你的值
#
# 本地开发：放在 .streamlit/secrets.toml
# Streamlit Cloud：在 App Settings → Secrets 中粘贴内容

[supabase]
url = "https://YOUR_PROJECT.supabase.co"
key = "YOUR_ANON_KEY"
